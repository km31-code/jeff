{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jeff",
  "version": "0.1.0",
  "identifier": "com.jeff.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Jeff — Full Workspace",
        "width": 960,
        "height": 680,
        "resizable": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
